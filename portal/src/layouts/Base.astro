---
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Fireside Strategies — Real Estate Private Equity',
  ogImage,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Fireside Strategies</title>
  <meta name="description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- GSAP (vendored from greensock/GSAP v3.15.0) -->
  <script is:inline src="/vendor/gsap/gsap.min.js"></script>
  <script is:inline src="/vendor/gsap/ScrollTrigger.min.js"></script>

  <slot name="head" />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <slot />
</body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: var(--font-sans);
    background: var(--paper);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }

  h1, h2, h3, .display {
    font-family: var(--font-display);
    font-weight: 300;
    letter-spacing: .01em;
  }

  .wrap {
    max-width: var(--wrap);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--slate);
  }

  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: var(--shadow);
  }

  /* Skip link */
  .skip-link {
    position: absolute;
    top: -100px;
    left: 16px;
    background: var(--gold);
    color: var(--navy);
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    z-index: 9999;
    transition: top .15s;
  }
  .skip-link:focus { top: 8px; }

  /* Focus visible — keyboard nav indicator */
  :focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
    border-radius: 3px;
  }

  @media (max-width: 640px) {
    :root { --gutter: 16px; }
  }
</style>
