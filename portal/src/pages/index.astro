---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Mark from '../components/Mark.astro';

const deals = await getCollection('deals');
const activeDeals = deals.filter(d => d.data.status === 'active');
---
<Base
  title="Active Deals"
  description="Fireside Strategies — Real Estate Private Equity. Institutional-quality multifamily assets in high-growth secondary markets."
>
  <Topbar />

  <main class="home" id="main-content">
    <div class="home-hero">
      <div class="home-hero-bg" aria-hidden="true"></div>
      <div class="wrap home-hero-inner">
        <div class="hero-badge">
          <Mark size="sm" />
          <span class="label">Fireside Strategies</span>
        </div>
        <h1 class="hero-title">
          <span class="line"><span class="line-i">Where capital</span></span>
          <span class="line"><span class="line-i meets">meets conviction</span></span>
        </h1>
        <p class="hero-sub">
          Institutional-quality multifamily assets in high-growth secondary markets —
          built for compelling, risk-adjusted returns.
        </p>
      </div>
    </div>

    <div class="deals-section">
      <div class="wrap">
        <div class="deals-header">
          <span class="label">Active Portfolio</span>
          <h2>Current deals</h2>
        </div>

        {activeDeals.length === 0 ? (
          <div class="empty">
            <p>No active deals at this time. Check back soon.</p>
          </div>
        ) : (
          <ol class="deals-list">
            {activeDeals.map((d, i) => (
              <li class="deal-entry">
                <a href={`/deals/${d.data.slug}`} class="deal-entry-link">
                  <div class="deal-figure">
                    {d.data.images?.hero && (
                      <img src={d.data.images.hero} alt="" loading="lazy" aria-hidden="true" />
                    )}
                    <span class="deal-figure-cap label">{d.data.location.city}, {d.data.location.state}</span>
                  </div>
                  <div class="deal-entry-body">
                    <span class="deal-index">{String(i + 1).padStart(2, '0')}</span>
                    <div class="deal-entry-meta label">{d.data.property.type} · {d.data.property.units} Units · {d.data.location.display}</div>
                    <h3 class="deal-entry-name">{d.data.name}</h3>
                    <p class="deal-entry-tagline">{d.data.copy.tagline}</p>
                    <div class="deal-entry-kpis">
                      <div class="deal-kpi">
                        <div class="deal-kpi-label">Target IRR</div>
                        <div class="deal-kpi-val">{d.data.teaser.targetIRR}</div>
                      </div>
                      <div class="deal-kpi">
                        <div class="deal-kpi-label">Equity Multiple</div>
                        <div class="deal-kpi-val">{d.data.teaser.equityMultiple}</div>
                      </div>
                      <div class="deal-kpi">
                        <div class="deal-kpi-label">Hold Period</div>
                        <div class="deal-kpi-val">{d.data.teaser.holdYears} <span class="u">yrs</span></div>
                      </div>
                    </div>
                    <span class="deal-entry-cta">Explore deal <i aria-hidden="true">→</i></span>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        )}
      </div>
    </div>
  </main>

  <footer class="foot">
    <div class="wrap">
      <p>
        This portal is an illustrative scenario model prepared for informational purposes only.
        Not an offer to sell or solicitation to purchase any security. © Fireside Strategies, LLC.
      </p>
    </div>
  </footer>
</Base>

<!-- Orchestrated entrance — masked line reveals + image overscan (respects reduced-motion) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const g  = (window as any).gsap;
    const ST = (window as any).ScrollTrigger;
    if (!g || !ST) return;

    g.registerPlugin(ST);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Hero: masked lines rise from behind their clip
    g.from('.hero-title .line-i', { yPercent: 112, duration: 1.1, ease: 'power4.out', stagger: 0.1, delay: 0.15 });
    g.from('.hero-badge', { opacity: 0, duration: 0.8, ease: 'power2.out', delay: 0.1 });
    g.from('.hero-sub', { opacity: 0, y: 18, duration: 0.9, ease: 'power2.out', delay: 0.5 });

    // Deal entries: image overscan + content stagger on scroll
    g.utils.toArray('.deal-entry').forEach((entry: Element) => {
      const img = entry.querySelector('.deal-figure img');
      if (img) {
        g.from(img, {
          scale: 1.14, duration: 1.2, ease: 'power2.out',
          scrollTrigger: { trigger: entry, start: 'top 84%', toggleActions: 'play none none none' },
        });
      }
      g.from(entry.querySelectorAll('.deal-entry-body > *'), {
        opacity: 0, y: 22, duration: 0.7, ease: 'power3.out', stagger: 0.06,
        scrollTrigger: { trigger: entry, start: 'top 80%', toggleActions: 'play none none none' },
      });
    });

    window.addEventListener('load', () => ST.refresh());
  });
</script>

<style>
  /* ── Home hero ───────────────────────────────────────────────────────────── */
  .home-hero {
    position: relative;
    background: var(--espresso);
    color: var(--bone);
    padding: clamp(96px, 16vh, 180px) 0 clamp(80px, 12vh, 130px);
    overflow: hidden;
  }
  .home-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(90% 70% at 82% 18%, rgba(199,93,58,.30) 0%, transparent 55%),
      radial-gradient(80% 60% at 8% 100%, rgba(90,38,32,.5) 0%, transparent 60%),
      linear-gradient(160deg, var(--espresso-2) 0%, var(--espresso) 64%);
  }
  .home-hero-inner { position: relative; z-index: 1; }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-bottom: 40px;
  }
  .hero-badge .label { color: var(--mist); }

  .hero-title {
    font-size: clamp(46px, 8vw, 104px);
    color: var(--bone);
    line-height: .96;
    letter-spacing: -.02em;
    margin-bottom: 34px;
    max-width: 12ch;
  }
  .hero-title .line { display: block; overflow: hidden; padding-bottom: .04em; }
  .hero-title .line-i { display: block; }
  .hero-title .meets { font-style: italic; color: var(--ember-glow); }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.5vw, 18px);
    color: var(--mist);
    line-height: 1.7;
    max-width: 540px;
  }

  /* ── Deals section ───────────────────────────────────────────────────────── */
  .deals-section {
    padding: clamp(64px, 9vw, 110px) 0 clamp(80px, 11vw, 130px);
    background: var(--bone);
  }

  .deals-header {
    margin-bottom: clamp(40px, 6vw, 72px);
    padding-bottom: 22px;
    border-bottom: var(--hair-light);
  }
  .deals-header .label { display: block; margin-bottom: 14px; }
  .deals-header h2 {
    font-size: clamp(32px, 5vw, 58px);
    color: var(--ink);
    letter-spacing: -.02em;
  }

  .deals-list { list-style: none; display: flex; flex-direction: column; gap: clamp(56px, 8vw, 96px); }

  /* Editorial deal entry */
  .deal-entry-link {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .deal-figure {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: linear-gradient(150deg, var(--espresso-2) 0%, var(--espresso) 100%);
    border-radius: 4px;
  }
  .deal-figure img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    filter: grayscale(.5) contrast(1.04) saturate(.82) brightness(.82);
    transition: transform .7s var(--ease-out), filter .7s var(--ease-out);
  }
  .deal-entry-link:hover .deal-figure img { transform: scale(1.04); filter: grayscale(.2) contrast(1.05) saturate(1) brightness(.9); }
  .deal-figure-cap {
    position: absolute;
    left: 18px;
    bottom: 16px;
    z-index: 1;
    color: var(--bone);
    text-shadow: 0 1px 12px rgba(27,21,18,.8);
  }

  .deal-index {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(30px, 4vw, 48px);
    font-weight: 300;
    color: var(--ember);
    line-height: 1;
    margin-bottom: 20px;
  }
  .deal-entry-meta { display: block; margin-bottom: 16px; color: var(--smoke); }
  .deal-entry-name {
    font-size: clamp(28px, 3.4vw, 46px);
    color: var(--ink);
    line-height: 1.02;
    letter-spacing: -.02em;
    margin-bottom: 18px;
  }
  .deal-entry-tagline {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink2);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 46ch;
  }

  .deal-entry-kpis {
    display: flex;
    gap: clamp(24px, 4vw, 48px);
    padding: 22px 0;
    border-top: var(--hair-light);
    border-bottom: var(--hair-light);
    margin-bottom: 26px;
  }
  .deal-kpi-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--smoke);
    margin-bottom: 8px;
  }
  .deal-kpi-val {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.4vw, 32px);
    font-weight: 300;
    color: var(--ink);
    line-height: 1;
  }
  .deal-kpi-val .u { font-family: var(--font-mono); font-size: .5em; color: var(--smoke); }

  .deal-entry-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ember-ink);
  }
  .deal-entry-cta i { font-style: normal; transition: transform .3s var(--ease-out); }
  .deal-entry-link:hover .deal-entry-cta i { transform: translateX(6px); }

  .empty { color: var(--ink2); font-size: 15px; }

  /* ── Footer ──────────────────────────────────────────────────────────────── */
  .foot {
    padding: 30px 0 56px;
    border-top: var(--hair-light);
    background: var(--bone);
  }
  .foot p { font-family: var(--font-mono); font-size: 10.5px; color: var(--smoke); line-height: 1.7; max-width: 70ch; }

  @media (max-width: 760px) {
    .deal-entry-link { grid-template-columns: 1fr; gap: 24px; }
    .deal-figure { aspect-ratio: 16 / 10; }
  }
</style>
