---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Mark from '../components/Mark.astro';

const deals = await getCollection('deals');
const activeDeals = deals.filter(d => d.data.status === 'active');
---
<Base
  title="Active Deals"
  description="Fireside Strategies — Real Estate Private Equity. Institutional-quality multifamily assets in high-growth secondary markets."
>
  <Topbar />

  <main class="home" id="main-content">
    <div class="home-hero">
      <div class="wrap">
        <div class="hero-badge">
          <Mark size="sm" />
          <span class="label">Fireside Strategies</span>
        </div>
        <h1 class="hero-title">
          Where Capital<br /><em>Meets Conviction</em>
        </h1>
        <p class="hero-sub">
          Institutional-quality multifamily assets in high-growth secondary markets —
          built for compelling, risk-adjusted returns.
        </p>
      </div>
    </div>

    <div class="deals-section">
      <div class="wrap">
        <div class="deals-header">
          <span class="label">Active Portfolio</span>
          <h2>Current Deals</h2>
        </div>

        {activeDeals.length === 0 ? (
          <div class="empty">
            <p>No active deals at this time. Check back soon.</p>
          </div>
        ) : (
          <div class="deals-grid">
            {activeDeals.map(d => (
              <a href={`/deals/${d.data.slug}`} class="deal-card card">
                <div class="deal-card-img">
                  {d.data.images?.hero && (
                    <img src={d.data.images.hero} alt="" class="deal-card-img-photo" loading="lazy" aria-hidden="true" />
                  )}
                  <div class="deal-card-overlay">
                    <span class="label">{d.data.property.type}</span>
                    <div class="deal-card-loc">
                      {d.data.location.city}, {d.data.location.state}
                    </div>
                  </div>
                </div>
                <div class="deal-card-body">
                  <div class="deal-card-meta label">
                    {d.data.property.units} Units · {d.data.location.display}
                  </div>
                  <h3 class="deal-card-name">{d.data.name}</h3>
                  <p class="deal-card-tagline">{d.data.copy.tagline}</p>
                  <div class="deal-card-kpis">
                    <div class="deal-kpi">
                      <div class="deal-kpi-label">Target IRR</div>
                      <div class="deal-kpi-val">{d.data.teaser.targetIRR}</div>
                    </div>
                    <div class="deal-kpi">
                      <div class="deal-kpi-label">Equity Multiple</div>
                      <div class="deal-kpi-val">{d.data.teaser.equityMultiple}</div>
                    </div>
                    <div class="deal-kpi">
                      <div class="deal-kpi-label">Hold Period</div>
                      <div class="deal-kpi-val">{d.data.teaser.holdYears} yrs</div>
                    </div>
                  </div>
                  <div class="deal-card-cta">
                    Explore Deal <span aria-hidden="true">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </main>

  <footer class="foot">
    <div class="wrap">
      <p>
        This portal is an illustrative scenario model prepared for informational purposes only.
        Not an offer to sell or solicitation to purchase any security. © Fireside Strategies, LLC.
      </p>
    </div>
  </footer>
</Base>

<!-- GSAP entrance on home (respects reduced-motion) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const g  = (window as any).gsap;
    const ST = (window as any).ScrollTrigger;
    if (!g || !ST) return;

    g.registerPlugin(ST);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    g.from('.hero-title', { opacity: 0, y: 32, duration: 1.0, ease: 'power3.out', delay: 0.1 });
    g.from('.hero-sub',   { opacity: 0, y: 20, duration: 0.8, ease: 'power2.out', delay: 0.4 });

    g.utils.toArray('.deal-card').forEach((el: Element, i: number) => {
      g.from(el, {
        opacity: 0, y: 28, duration: 0.65, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        delay: i * 0.1,
      });
    });

    window.addEventListener('load', () => ST.refresh());
  });
</script>

<style>
  /* ── Home hero ───────────────────────────────────────────────────────────── */
  .home-hero {
    background: var(--navy);
    padding: 96px 0 72px;
    color: #fff;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .hero-badge .label { color: var(--mist); }

  .hero-title {
    font-size: clamp(44px, 7vw, 88px);
    color: #fff;
    line-height: 1.0;
    margin-bottom: 24px;
    max-width: 700px;
  }
  .hero-title em {
    font-style: normal;
    color: var(--gold2);
  }

  .hero-sub {
    font-size: clamp(14px, 1.6vw, 17px);
    color: var(--mist);
    line-height: 1.65;
    max-width: 520px;
  }

  /* ── Deals section ───────────────────────────────────────────────────────── */
  .deals-section {
    padding: 60px 0 80px;
    background: var(--paper);
  }

  .deals-header {
    margin-bottom: 32px;
  }
  .deals-header .label { display: block; margin-bottom: 8px; }
  .deals-header h2 {
    font-size: clamp(28px, 4vw, 40px);
    color: var(--navy);
  }

  .deals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 24px;
  }

  /* Deal card */
  .deal-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform .25s var(--ease-out), box-shadow .25s var(--ease-out);
  }
  .deal-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  @media (prefers-reduced-motion: reduce) {
    .deal-card { transition: box-shadow .25s; }
    .deal-card:hover { transform: none; }
  }

  .deal-card-img {
    width: 100%;
    height: 220px;
    background: linear-gradient(135deg, var(--navy2) 0%, var(--navy3) 50%, var(--navy) 100%);
    border-radius: 12px 12px 0 0;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .deal-card-img-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .deal-card-img:not(:has(.deal-card-img-photo))::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg, transparent, transparent 24px,
      rgba(255,255,255,.015) 24px, rgba(255,255,255,.015) 25px
    );
  }
  .deal-card-overlay {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 16px 20px;
    background: linear-gradient(to top, rgba(22,41,59,.85) 0%, transparent 100%);
  }
  .deal-card-overlay .label { color: var(--mist); display: block; margin-bottom: 4px; }
  .deal-card-loc {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 300;
    color: #fff;
  }

  .deal-card-body { padding: 24px; }
  .deal-card-meta { display: block; margin-bottom: 8px; }
  .deal-card-name {
    font-size: 22px;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .deal-card-tagline {
    font-size: 13px;
    color: var(--ink2);
    line-height: 1.6;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .deal-card-kpis {
    display: flex;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 16px;
  }
  .deal-kpi { text-align: center; flex: 1; }
  .deal-kpi-label { font-size: 10px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--slate); margin-bottom: 4px; }
  .deal-kpi-val { font-family: var(--font-display); font-size: 22px; font-weight: 300; color: var(--gold); }

  .deal-card-cta {
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: .06em;
    color: var(--navy);
    text-transform: uppercase;
  }

  .empty { color: var(--ink2); font-size: 15px; }

  /* ── Footer ──────────────────────────────────────────────────────────────── */
  .foot {
    padding: 26px 0 50px;
    border-top: 1px solid var(--line);
    background: var(--paper);
  }
  .foot p { font-size: 11px; color: var(--ink2); line-height: 1.65; }

  @media (max-width: 560px) {
    .deals-grid { grid-template-columns: 1fr; }
  }
</style>
