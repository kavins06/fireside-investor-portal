---
import { getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Hero from '../../components/deal/Hero.astro';
import PropertySection from '../../components/deal/PropertySection.astro';
import ThesisSection from '../../components/deal/ThesisSection.astro';
import MarketPulse from '../../components/deal/MarketPulse.astro';
import UnlockGate from '../../components/deal/UnlockGate.astro';
import ModelIsland from '../../components/deal/ModelIsland.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const entry = await getEntry('deals', slug);
if (!entry) return Astro.redirect('/');

const deal = entry.data;
---
<Base
  title={deal.name}
  description={deal.copy.tagline}
>
  <Topbar tag="Active Deal" />

  <Hero
    name={deal.name}
    location={deal.location.display}
    tagline={deal.copy.tagline}
    heroImage={deal.images?.hero}
    imageCredit={deal.images?.credit}
    teaser={deal.teaser}
    propertyType={deal.property.type}
    units={deal.property.units}
  />

  <PropertySection
    property={deal.property}
    transaction={deal.transaction}
    location={deal.location}
    exteriorImage={deal.images?.exterior}
    imageCredit={deal.images?.credit}
  />

  <ThesisSection
    copy={deal.copy}
    dealName={deal.name}
  />

  {deal.marketFindings && deal.marketFindings.length > 0 && (
    <MarketPulse
      findings={deal.marketFindings}
      dealName={deal.name}
      marketLabel={deal.marketLabel}
      marketAsOf={deal.marketAsOf}
    />
  )}

  <UnlockGate
    dealSlug={deal.slug}
    teaser={deal.teaser}
  />

  <!-- Full-screen takeover; hidden via its own CSS until the gate is passed -->
  <ModelIsland
    engineData={deal.engine}
    dealName={deal.name}
    location={deal.location}
    property={deal.property}
    teaser={deal.teaser}
  />

  <!-- Disclosure footer -->
  <footer class="foot">
    <div class="wrap">
      <p>
        This portal is an illustrative scenario model prepared for informational purposes only.
        The base case mirrors the sponsor's closing pro forma; projected figures are inherently
        predictive and not a guarantee of results. This material does not constitute an offer to
        sell or a solicitation to purchase an interest in Fireside Fund LP, which may be made only
        via a confidential private placement memorandum. An investment is speculative and subject
        to risk of loss, including loss of principal. Past performance is not necessarily indicative
        of future results. © Fireside Strategies, LLC.
      </p>
    </div>
  </footer>
</Base>

<!-- GSAP scroll reveals (respects prefers-reduced-motion) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const g = (window as any).gsap;
    const ST = (window as any).ScrollTrigger;
    if (!g || !ST) return;

    g.registerPlugin(ST);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Deal hero — choreographed load: meta, masked title lines, tagline, figures
    g.from('.hero .hero-meta', { opacity: 0, duration: 0.8, ease: 'power2.out', delay: 0.2 });
    g.from('.hero .title-line1, .hero .title-line2', {
      yPercent: 116, duration: 1.1, ease: 'power4.out', stagger: 0.1, delay: 0.3,
    });
    g.from('.hero .hero-tagline', { opacity: 0, y: 18, duration: 0.9, ease: 'power2.out', delay: 0.7 });
    g.from('.hero .teaser-kpi', { opacity: 0, y: 18, duration: 0.7, ease: 'power3.out', stagger: 0.08, delay: 0.85 });

    // Section reveals — content groups marked .reveal, staggered per section
    g.utils.toArray('.deal-section').forEach((sec: Element) => {
      const items = sec.querySelectorAll('.reveal');
      if (!items.length) return;
      g.from(items, {
        opacity: 0, y: 28, duration: 0.8, ease: 'power3.out', stagger: 0.1,
        scrollTrigger: { trigger: sec, start: 'top 82%', toggleActions: 'play none none none' },
      });
    });

    // Duotone imagery scales in from a slight overscan
    g.utils.toArray('.scale-in').forEach((img: Element) => {
      g.from(img, {
        scale: 1.12, duration: 1.2, ease: 'power2.out',
        scrollTrigger: { trigger: img, start: 'top 88%', toggleActions: 'play none none none' },
      });
    });

    window.addEventListener('load', () => ST.refresh());
  });
</script>

<style>
  .foot {
    padding: 32px 0 56px;
    border-top: var(--hair-light);
    background: var(--bone);
  }
  .foot p {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--smoke);
    line-height: 1.75;
    max-width: 90ch;
  }
</style>
