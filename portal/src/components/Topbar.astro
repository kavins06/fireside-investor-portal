---
import Mark from './Mark.astro';

interface Props {
  tag?: string;
}
const { tag = 'Investor Portal' } = Astro.props;
---
<header class="topbar">
  <div class="wrap">
    <a href="/" class="brand" aria-label="Fireside Strategies — Home">
      <Mark />
      <div class="wordmark">
        FIRESIDE<span>STRATEGIES</span>
      </div>
    </a>
    <div class="topbar-tag">{tag}</div>
  </div>
</header>

<style>
  .topbar {
    background: var(--espresso);
    color: var(--bone);
    padding: 16px 0;
    border-bottom: var(--hair-dark);
  }
  .topbar .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 13px;
    text-decoration: none;
    color: inherit;
  }
  .wordmark {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: .24em;
    font-size: 13px;
    color: var(--bone);
  }
  .wordmark span {
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--mist);
    letter-spacing: .34em;
    font-size: 10px;
    display: block;
    margin-top: 2px;
  }
  .topbar-tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--mist);
    font-weight: 400;
  }
</style>
