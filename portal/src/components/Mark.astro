---
interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;
---
<div class:list={['mark', `mark--${size}`]}>
  <b>F</b>
  <s>S</s>
  <i></i>
</div>

<style>
  .mark {
    border: 1.5px solid rgba(242,235,223,.5);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 4px;
    position: relative;
    flex-shrink: 0;
  }
  .mark--md { width: 34px; height: 34px; }
  .mark--sm { width: 26px; height: 26px; padding: 3px; }

  .mark b {
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--ember);
    font-size: 17px;
    line-height: 1;
    margin-bottom: 4px;   /* lift the F clear of the accent bar so it never reads as “E” */
  }
  .mark--sm b { font-size: 13px; margin-bottom: 3px; }

  .mark s {
    position: absolute;
    top: 5px;
    right: 5px;
    font-family: var(--font-mono);
    font-size: 8.5px;
    color: var(--bone);
    text-decoration: none;
    font-weight: 500;
  }
  .mark--sm s { top: 3px; right: 3px; font-size: 7px; }

  .mark i {
    position: absolute;
    bottom: 3px;
    left: 5px;
    width: 10px;
    height: 2px;
    background: var(--ember);
  }
  .mark--sm i { bottom: 3px; left: 3px; width: 8px; }
</style>
