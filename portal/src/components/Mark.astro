---
interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;
---
<div class:list={['mark', `mark--${size}`]}>
  <b>F</b>
  <s>S</s>
  <i></i>
</div>

<style>
  .mark {
    border: 1.5px solid rgba(255,255,255,.55);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 4px;
    position: relative;
    flex-shrink: 0;
  }
  .mark--md { width: 34px; height: 34px; }
  .mark--sm { width: 26px; height: 26px; padding: 3px; }

  .mark b {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    color: var(--gold);
    font-size: 18px;
    line-height: .8;
  }
  .mark--sm b { font-size: 14px; }

  .mark s {
    position: absolute;
    top: 5px;
    right: 5px;
    font-size: 9px;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
  }
  .mark--sm s { top: 3px; right: 3px; font-size: 7px; }

  .mark i {
    position: absolute;
    bottom: 4px;
    left: 5px;
    width: 11px;
    height: 2px;
    background: var(--gold);
  }
  .mark--sm i { bottom: 3px; left: 3px; width: 8px; }
</style>
