---
interface Props {
  property: {
    type:        string;
    units:       number;
    unitMix?:    string;
    yearBuilt:   number;
    buildings?:  number;
    acres?:      number;
    sqftPerUnit?: number;
    occupancy?:  string;
    coGP?:       string;
  };
  transaction: {
    purchasePrice:   number;
    totalEquity:     number;
    agencyDebt:      number;
    capImprovements: number;
  };
  location: {
    display: string;
    address: string;
    city:    string;
    state:   string;
    zip:     string;
  };
  exteriorImage?: string;
  imageCredit?:   string;
}
const { property, transaction, location, exteriorImage, imageCredit } = Astro.props;

const fmt$ = (n: number) =>
  '$' + Math.round(n).toLocaleString('en-US');
const fmt$M = (n: number) =>
  '$' + (n / 1_000_000).toFixed(2) + 'M';

const specs = [
  { label: 'Units',           value: String(property.units)       },
  { label: 'Unit Mix',        value: property.unitMix ?? '—'      },
  { label: 'Year Built',      value: String(property.yearBuilt)   },
  { label: 'Buildings',       value: String(property.buildings ?? '—') },
  { label: 'Acres',           value: property.acres ? property.acres.toFixed(2) : '—' },
  { label: 'Sq Ft / Unit',    value: property.sqftPerUnit ? `~${property.sqftPerUnit}` : '—' },
  { label: 'Occupancy',       value: property.occupancy ?? '—'    },
  { label: 'Co-GP',           value: property.coGP ?? '—'         },
].filter(s => s.value !== '—');

const txn = [
  { label: 'Purchase Price',       value: fmt$(transaction.purchasePrice),    sub: fmt$(transaction.purchasePrice / property.units) + ' / unit' },
  { label: 'Total Equity',         value: fmt$M(transaction.totalEquity),     sub: '30.1% of total cost' },
  { label: 'Agency Debt',          value: fmt$M(transaction.agencyDebt),      sub: '5.23% fixed · interest-only' },
  { label: 'Capital Improvements', value: fmt$M(transaction.capImprovements), sub: fmt$(transaction.capImprovements / property.units) + ' / unit' },
];
---
<section class="property-section deal-section" id="property">
  <div class="wrap">
    <div class="section-header reveal">
      <span class="label">The Asset</span>
      <h2>Property &amp; location</h2>
    </div>

    <div class="property-grid">
      <!-- Specs -->
      <div class="specs-col reveal">
        <div class="specs-address">
          <div class="label" style="margin-bottom:8px">Location</div>
          <div class="address-line">{location.display}</div>
          <div class="address-sub">{location.address}, {location.zip}</div>
        </div>

        <div class="specs-list">
          {specs.map(s => (
            <div class="spec-row">
              <span class="spec-label">{s.label}</span>
              <span class="spec-val">{s.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Property image -->
      <div class="image-col reveal">
        <div class="property-img-wrap">
          {exteriorImage ? (
            <img
              src={exteriorImage}
              alt={`Exterior view — ${location.city}, ${location.state}`}
              class="property-img scale-in"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="property-img-placeholder" aria-hidden="true"></div>
          )}
          <div class="img-overlay">
            <span class="label">Property</span>
            <div class="img-loc">{location.city}, {location.state}</div>
          </div>
          {imageCredit && (
            <span class="img-credit">{imageCredit}</span>
          )}
        </div>
      </div>
    </div>

    <!-- Transaction snapshot -->
    <div class="txn-row">
      <div class="section-sub-header reveal">
        <span class="label">At a Glance</span>
        <h3>Transaction snapshot</h3>
      </div>
      <div class="txn-grid">
        {txn.map(t => (
          <div class="txn-card reveal">
            <div class="label">{t.label}</div>
            <div class="txn-val">{t.value}</div>
            <div class="txn-sub">{t.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .property-section {
    background: var(--bone);
    padding: clamp(72px, 10vw, 120px) 0 clamp(64px, 8vw, 96px);
  }

  .section-header {
    margin-bottom: clamp(40px, 6vw, 64px);
  }
  .section-header .label { display: block; margin-bottom: 14px; }
  .section-header h2 {
    font-size: clamp(32px, 5vw, 56px);
    color: var(--ink);
    letter-spacing: -.02em;
  }

  .property-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
    margin-bottom: clamp(56px, 7vw, 88px);
  }

  .specs-address {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: var(--hair-light);
  }
  .address-line {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 300;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.1;
  }
  .address-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--smoke);
  }

  .specs-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 13px 0;
    border-bottom: var(--hair-light);
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-label { font-size: 13px; color: var(--ink2); }
  .spec-val { font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--ink); }

  /* Image container — duotone, art-directed */
  .property-img-wrap {
    position: relative;
    width: 100%;
    height: clamp(300px, 42vw, 460px);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(150deg, var(--espresso-2) 0%, var(--espresso) 100%);
  }
  .property-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(.5) contrast(1.04) saturate(.82) brightness(.84);
  }
  .property-img-placeholder {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(90% 70% at 70% 30%, rgba(199,93,58,.18) 0%, transparent 55%);
  }
  .img-overlay {
    position: relative;
    z-index: 1;
    padding: 22px 26px;
    background: linear-gradient(to top, rgba(27,21,18,.9) 0%, transparent 100%);
    width: 100%;
  }
  .img-overlay .label { color: var(--mist); margin-bottom: 5px; display: block; }
  .img-loc { font-family: var(--font-display); font-size: clamp(20px, 2.4vw, 26px); color: var(--bone); font-weight: 300; }
  .img-credit {
    position: absolute;
    top: 12px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: rgba(242,235,223,.45);
    z-index: 2;
  }

  /* Transaction */
  .section-sub-header { margin-bottom: 24px; }
  .section-sub-header .label { display: block; margin-bottom: 8px; }
  .section-sub-header h3 {
    font-size: clamp(22px, 3vw, 34px);
    color: var(--ink);
    letter-spacing: -.01em;
  }
  .txn-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: var(--hair-light);
    border-left: var(--hair-light);
  }
  .txn-card {
    padding: 24px;
    background: transparent;
    border: none;
    border-right: var(--hair-light);
    border-bottom: var(--hair-light);
  }
  .txn-card .label { display: block; margin-bottom: 14px; }
  .txn-val {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.6vw, 30px);
    font-weight: 300;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 6px;
  }
  .txn-sub { font-family: var(--font-mono); font-size: 11px; color: var(--smoke); }

  @media (max-width: 900px) {
    .property-grid { grid-template-columns: 1fr; }
    .txn-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .txn-grid { grid-template-columns: 1fr; }
  }
</style>
