<style is:global>
  /* Cash-flow table reveal. Global (not Astro-scoped) so the @keyframes name can't fall
     out of sync with the rules; constrained to #model-overlay by selector. JS adds
     .reveal-rows on first scroll-into-view and removes it on animationend (so lever-driven
     row re-renders don't replay it). Opacity animates reliably on <tr>; translateY is a
     bonus where supported. */
  @keyframes cfRowIn { from { opacity: 0; transform: translateY(9px); } to { opacity: 1; transform: none; } }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr { animation: cfRowIn 0.5s cubic-bezier(.22,.7,.3,1) both; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(1) { animation-delay: .03s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(2) { animation-delay: .09s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(3) { animation-delay: .15s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(4) { animation-delay: .21s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(5) { animation-delay: .27s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(6) { animation-delay: .33s; }
  #model-overlay .table-section.reveal-rows #cf-table tbody tr:nth-child(7) { animation-delay: .39s; }
