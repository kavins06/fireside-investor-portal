---
interface Finding {
  tag:      'supportive' | 'watch' | 'challenge';
  headline: string;
  body:     string;
  source:   string;
  date:     string;
}
interface Props {
  findings: Finding[];
  dealName: string;
}
const { findings, dealName } = Astro.props;

const tagLabels: Record<Finding['tag'], string> = {
  supportive: 'Supportive',
  watch:      'Watch',
  challenge:  'Challenge',
};
---
<section class="market-pulse" id="market-pulse" aria-labelledby="market-pulse-title">
  <div class="wrap">
    <div class="section-header">
      <span class="label">Submarket Context</span>
      <h2 id="market-pulse-title">Market Pulse</h2>
      <p class="section-sub">
        Key findings for the Greensboro–Piedmont Triad multifamily submarket. Marked
        <strong>illustrative</strong> — drawn from publicly available sources as of mid-2025.
      </p>
    </div>

    <div class="findings-grid">
      {findings.map(f => (
        <div class={`finding-card finding-card--${f.tag}`}>
          <div class="finding-top">
            <span class={`finding-tag finding-tag--${f.tag}`} aria-label={`Tagged: ${tagLabels[f.tag]}`}>
              {tagLabels[f.tag]}
            </span>
            <span class="finding-date">{f.date}</span>
          </div>
          <h3 class="finding-headline">{f.headline}</h3>
          <p class="finding-body">{f.body}</p>
          <div class="finding-source">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <circle cx="6" cy="6" r="5.5" stroke="currentColor"/>
              <path d="M6 5.5V8.5M6 3.5v.5" stroke="currentColor" stroke-linecap="round"/>
            </svg>
            {f.source}
          </div>
        </div>
      ))}
    </div>

    <p class="illustrative-note" role="note">
      Illustrative market context only — not investment advice. Sources cited are third-party and
      Fireside Strategies makes no representation as to their accuracy or completeness.
    </p>
  </div>
</section>

<style>
  .market-pulse {
    background: var(--navy);
    padding: 72px 0 64px;
    color: #fff;
  }

  .section-header {
    margin-bottom: 40px;
    max-width: 680px;
  }
  .section-header .label { display: block; margin-bottom: 8px; }
  .section-header h2 {
    font-size: clamp(26px, 4vw, 38px);
    color: #fff;
    margin-bottom: 14px;
  }
  .section-sub {
    font-size: 13.5px;
    color: var(--mist);
    line-height: 1.65;
  }
  .section-sub strong { color: var(--gold2); font-weight: 500; }

  /* Grid */
  .findings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .finding-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background .2s;
  }
  .finding-card:hover {
    background: rgba(255,255,255,.07);
  }

  /* Tag accent line */
  .finding-card--supportive { border-top: 3px solid var(--good); }
  .finding-card--watch      { border-top: 3px solid var(--gold); }
  .finding-card--challenge  { border-top: 3px solid var(--bad);  }

  .finding-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .finding-tag {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }
  .finding-tag--supportive { background: rgba(63,125,94,.25);  color: #6ec89a; }
  .finding-tag--watch      { background: rgba(207,159,59,.20); color: var(--gold2); }
  .finding-tag--challenge  { background: rgba(187,95,72,.20);  color: #e8917a; }

  .finding-date {
    font-size: 10px;
    color: rgba(255,255,255,.35);
    white-space: nowrap;
  }

  .finding-headline {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    line-height: 1.25;
  }

  .finding-body {
    font-size: 13px;
    color: var(--mist);
    line-height: 1.65;
    flex: 1;
  }

  .finding-source {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10.5px;
    color: rgba(255,255,255,.3);
    margin-top: 4px;
  }

  .illustrative-note {
    font-size: 10.5px;
    color: rgba(255,255,255,.25);
    line-height: 1.6;
    max-width: 700px;
    border-top: 1px solid rgba(255,255,255,.08);
    padding-top: 20px;
  }

  @media (max-width: 560px) {
    .findings-grid { grid-template-columns: 1fr; }
  }
</style>
