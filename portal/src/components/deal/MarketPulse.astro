---
interface Finding {
  tag:      'supportive' | 'watch' | 'challenge';
  headline: string;
  body:     string;
  source:   string;
  date:     string;
}
interface Props {
  findings: Finding[];
  dealName: string;
  marketLabel?: string;   // e.g. "Greensboro–Piedmont Triad multifamily submarket"
  marketAsOf?: string;    // e.g. "Q2 2026" — the recency of the scan; omit if unknown
}
const { findings, dealName, marketLabel, marketAsOf } = Astro.props;

const tagLabels: Record<Finding['tag'], string> = {
  supportive: 'Supportive',
  watch:      'Watch',
  challenge:  'Challenge',
};
---
<section class="market-pulse deal-section" id="market-pulse" aria-labelledby="market-pulse-title">
  <div class="wrap">
    <div class="section-header reveal">
      <span class="label">Submarket Context</span>
      <h2 id="market-pulse-title">Market pulse</h2>
      <p class="section-sub">
        Key findings for {marketLabel ?? 'this submarket'} —
        <strong>illustrative</strong>, drawn from publicly available sources{marketAsOf ? ` as of ${marketAsOf}` : ''}.
      </p>
    </div>

    <div class="findings-grid">
      {findings.map(f => (
        <div class={`finding finding--${f.tag} reveal`}>
          <div class="finding-top">
            <span class="finding-status">
              <span class="finding-swatch" aria-hidden="true"></span>
              <span class="finding-status-label" aria-label={`Tagged: ${tagLabels[f.tag]}`}>{tagLabels[f.tag]}</span>
            </span>
            <span class="finding-date">{f.date}</span>
          </div>
          <h3 class="finding-headline">{f.headline}</h3>
          <p class="finding-body">{f.body}</p>
          <div class="finding-source">{f.source}</div>
        </div>
      ))}
    </div>

    <p class="illustrative-note" role="note">
      Illustrative market context only — not investment advice. Sources cited are third-party and
      Fireside Strategies makes no representation as to their accuracy or completeness.
    </p>
  </div>
</section>

<style>
  .market-pulse {
    background: var(--bone);
    padding: clamp(72px, 10vw, 120px) 0 clamp(64px, 8vw, 96px);
    color: var(--ink);
  }

  .section-header {
    margin-bottom: clamp(40px, 5vw, 56px);
    max-width: 720px;
  }
  .section-header .label { display: block; margin-bottom: 14px; }
  .section-header h2 {
    font-size: clamp(32px, 5vw, 56px);
    color: var(--ink);
    letter-spacing: -.02em;
    margin-bottom: 18px;
  }
  .section-sub {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink2);
    line-height: 1.7;
  }
  .section-sub strong { color: var(--ember-ink); font-weight: 600; }

  /* Grid of flat editorial findings */
  .findings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0;
    margin-bottom: 32px;
    border-left: var(--hair-light);
  }

  .finding {
    --tag: var(--smoke);
    border-top: 2px solid var(--tag);
    border-right: var(--hair-light);
    border-bottom: var(--hair-light);
    padding: 26px 26px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .finding--supportive { --tag: var(--good); }
  .finding--watch      { --tag: var(--watch); }
  .finding--challenge  { --tag: var(--bad); }

  .finding-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .finding-status { display: inline-flex; align-items: center; gap: 8px; }
  .finding-swatch { width: 8px; height: 8px; background: var(--tag); border-radius: 1px; }
  .finding-status-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink2);
  }
  .finding-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--smoke);
    white-space: nowrap;
  }

  .finding-headline {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.22;
    letter-spacing: -.01em;
  }

  .finding-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink2);
    line-height: 1.7;
    flex: 1;
  }

  .finding-source {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--smoke);
    margin-top: 4px;
    padding-top: 12px;
    border-top: var(--hair-light);
  }

  .illustrative-note {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--smoke);
    line-height: 1.7;
    max-width: 80ch;
    border-top: var(--hair-light);
    padding-top: 22px;
  }

  @media (max-width: 560px) {
    .findings-grid { grid-template-columns: 1fr; }
  }
</style>
