---
interface Props {
  copy: {
    thesis:      string;
    marketNotes?: string;
  };
  dealName: string;
}
const { copy, dealName } = Astro.props;
---
<section class="thesis-section" id="thesis">
  <div class="wrap">
    <div class="thesis-grid">
      <div class="thesis-col">
        <span class="label" style="color:var(--gold)">Investment Thesis</span>
        <h2>Why We Bought It</h2>
        <div class="thesis-body">
          {copy.thesis.split('\n').filter(Boolean).map((para: string) => (
            <p>{para}</p>
          ))}
        </div>
      </div>

      {copy.marketNotes && (
        <div class="market-col">
          <span class="label" style="color:var(--gold)">Market Pulse</span>
          <h3>The Demand Story</h3>
          <div class="market-body">
            {copy.marketNotes.split('\n').filter(Boolean).map((para: string) => (
              <p>{para}</p>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .thesis-section {
    background: var(--navy);
    padding: 80px 0;
    color: #fff;
  }

  .thesis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .thesis-col .label,
  .market-col .label {
    display: block;
    margin-bottom: 10px;
  }

  .thesis-col h2 {
    font-size: clamp(28px, 4vw, 40px);
    color: #fff;
    margin-bottom: 24px;
  }

  .market-col h3 {
    font-size: clamp(22px, 3vw, 30px);
    color: #fff;
    margin-bottom: 20px;
  }

  .thesis-body p,
  .market-body p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--mist);
    margin-bottom: 16px;
  }
  .thesis-body p:last-child,
  .market-body p:last-child { margin-bottom: 0; }

  @media (max-width: 860px) {
    .thesis-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
