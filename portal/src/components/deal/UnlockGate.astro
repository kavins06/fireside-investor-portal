---
interface Props {
  dealSlug: string;
  teaser: {
    targetIRR:      string;
    equityMultiple: string;
    holdYears:      number;
  };
}
const { dealSlug, teaser } = Astro.props;
---
<div id="unlock-gate" class="gate-section">
  <div class="wrap">
    <!-- Locked state: email form -->
    <div class="gate-card">
      <div class="gate-inner">
        <div class="gate-teaser">
          <div class="gt-item">
            <div class="label">Target LP IRR</div>
            <div class="gt-val">{teaser.targetIRR}</div>
          </div>
          <div class="gt-divider" aria-hidden="true"></div>
          <div class="gt-item">
            <div class="label">Equity Multiple</div>
            <div class="gt-val">{teaser.equityMultiple}</div>
          </div>
          <div class="gt-divider" aria-hidden="true"></div>
          <div class="gt-item">
            <div class="label">Target Hold</div>
            <div class="gt-val">{teaser.holdYears} yrs</div>
          </div>
        </div>

        <div class="gate-cta">
          <span class="label gate-kicker">By Invitation</span>
          <h2 class="gate-title">Access the live returns model</h2>
          <p class="gate-sub">
            Enter your email to unlock the full interactive model — scenario levers,
            cash-flow projections, and the LP/GP waterfall.
          </p>

          <form id="unlock-form" class="gate-form" novalidate>
            <input
              type="email"
              id="gate-email"
              name="email"
              placeholder="your@email.com"
              autocomplete="email"
              required
            />
            <button type="submit" id="gate-submit">
              <span id="gate-btn-text">Unlock Model</span>
            </button>
          </form>

          <p id="gate-error" class="gate-error" aria-live="polite" hidden></p>

          <p class="gate-disclaimer">
            Your email is used only for Fireside Strategies, LLC to follow up directly.
          </p>
        </div>
      </div>
    </div>

    <!-- Unlocked state: persistent CTA to (re)open the model -->
    <div id="gate-unlocked" class="gate-unlocked" hidden>
      <div class="gu-inner">
        <div class="gu-text">
          <span class="label gu-kicker">Access granted</span>
          <h2 class="gu-title">The live returns model is unlocked</h2>
          <p class="gu-sub">Open the full interactive dashboard — adjust the levers and watch the returns recompute.</p>
        </div>
        <button id="open-model-cta" type="button" class="gu-btn">
          View the live returns model <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ dealSlug }}>
  const STORAGE_KEY = `fireside_unlocked_${dealSlug}`;

  const gateCard = document.querySelector('#unlock-gate .gate-card');
  const unlocked = document.getElementById('gate-unlocked');

  function showUnlockedState() {
    if (gateCard) gateCard.style.display = 'none';
    if (unlocked) unlocked.hidden = false;
  }

  function openTakeover() {
    if (typeof window.firesideOpenModel === 'function') window.firesideOpenModel();
  }

  // Returning visitor — show the CTA but do NOT auto-open the takeover.
  if (localStorage.getItem(STORAGE_KEY) === '1') {
    showUnlockedState();
  }

  document.getElementById('open-model-cta')?.addEventListener('click', openTakeover);

  const form    = document.getElementById('unlock-form');
  const errEl   = document.getElementById('gate-error');
  const btnTxt  = document.getElementById('gate-btn-text');
  const emailEl = document.getElementById('gate-email');

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    const email = emailEl?.value?.trim() ?? '';

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (errEl) { errEl.textContent = 'Please enter a valid email address.'; errEl.hidden = false; }
      emailEl?.focus();
      return;
    }

    if (errEl) errEl.hidden = true;
    if (btnTxt) btnTxt.textContent = 'Unlocking…';
    const btn = document.getElementById('gate-submit');
    if (btn) btn.setAttribute('disabled', '');

    try {
      const res = await fetch('/api/unlock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, deal_slug: dealSlug }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data?.error ?? 'Something went wrong. Please try again.');
      }

      localStorage.setItem(STORAGE_KEY, '1');

      // Cinematic hand-off: fade the gate card, swap to the unlocked CTA, open the takeover.
      const g = window.gsap;
      const launch = () => { showUnlockedState(); openTakeover(); };
      if (g && gateCard && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        g.to(gateCard, { opacity: 0, y: -12, duration: 0.35, ease: 'power2.in', onComplete: launch });
      } else {
        launch();
      }
    } catch (err) {
      if (errEl) {
        errEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        errEl.hidden = false;
      }
      if (btnTxt) btnTxt.textContent = 'Unlock Model';
      if (btn) btn.removeAttribute('disabled');
    }
  });
</script>

<style>
  .gate-section {
    background: var(--bone);
    padding: clamp(64px, 9vw, 110px) 0 clamp(72px, 9vw, 110px);
  }

  .gate-card {
    position: relative;
    background:
      radial-gradient(90% 80% at 88% 12%, rgba(199,93,58,.26) 0%, transparent 55%),
      radial-gradient(70% 70% at 4% 100%, rgba(90,38,32,.42) 0%, transparent 60%),
      var(--espresso);
    border-radius: 4px;
    overflow: hidden;
  }

  .gate-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    min-height: 380px;
  }

  /* Teaser column — solid, hairline-separated (no frosted glass) */
  .gate-teaser {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    padding: 52px 44px;
    border-right: var(--hair-dark);
  }
  .gt-item { padding: 18px 0; }
  .gt-item .label { color: var(--mist); margin-bottom: 10px; }
  .gt-val {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 46px);
    font-weight: 300;
    color: var(--bone);
    line-height: 1;
  }
  .gt-divider { width: 100%; max-width: 64px; height: 1px; background: rgba(242,235,223,.14); }

  /* CTA column */
  .gate-cta {
    padding: 52px 52px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gate-kicker { display: block; margin-bottom: 16px; color: var(--ember-glow); }
  .gate-title {
    font-size: clamp(26px, 3.4vw, 40px);
    color: var(--bone);
    letter-spacing: -.015em;
    line-height: 1.02;
    margin-bottom: 14px;
  }
  .gate-sub {
    font-family: var(--font-sans);
    font-size: 14.5px;
    color: var(--mist);
    line-height: 1.7;
    margin-bottom: 30px;
    max-width: 420px;
  }

  /* Form */
  .gate-form {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .gate-form input[type=email] {
    flex: 1;
    min-width: 220px;
    padding: 14px 16px;
    border: 1px solid rgba(242,235,223,.22);
    border-radius: 2px;
    background: rgba(242,235,223,.05);
    color: var(--bone);
    font-family: var(--font-sans);
    font-size: 14px;
    outline: none;
    transition: border-color .2s, background .2s;
  }
  .gate-form input[type=email]::placeholder { color: var(--smoke); }
  .gate-form input[type=email]:focus { border-color: var(--ember); background: rgba(242,235,223,.08); }

  .gate-form button {
    padding: 14px 28px;
    background: var(--ember-ink);
    color: var(--bone);
    border: none;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: .12em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background .2s, opacity .2s;
  }
  .gate-form button:hover  { background: var(--ember-glow); color: var(--espresso); }
  .gate-form button:disabled { opacity: .6; cursor: default; }

  .gate-error {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #E89A7A;
    margin-bottom: 8px;
  }
  .gate-disclaimer {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--smoke);
    letter-spacing: .02em;
  }

  /* Unlocked CTA panel */
  .gate-unlocked {
    position: relative;
    background:
      radial-gradient(80% 90% at 92% 0%, rgba(199,93,58,.22) 0%, transparent 55%),
      var(--espresso);
    border-radius: 4px;
    overflow: hidden;
  }
  .gu-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    padding: 40px 48px;
    flex-wrap: wrap;
  }
  .gu-kicker { display: block; margin-bottom: 10px; color: var(--ember-glow); }
  .gu-title {
    font-size: clamp(22px, 2.8vw, 32px);
    color: var(--bone);
    letter-spacing: -.01em;
    margin-bottom: 10px;
  }
  .gu-sub {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--mist);
    line-height: 1.65;
    max-width: 460px;
  }
  .gu-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 28px;
    background: var(--ember-ink);
    color: var(--bone);
    border: none;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: .12em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background .2s, color .2s;
  }
  .gu-btn span { transition: transform .3s var(--ease-out); }
  .gu-btn:hover { background: var(--ember-glow); color: var(--espresso); }
  .gu-btn:hover span { transform: translateX(5px); }

  @media (max-width: 700px) {
    .gate-inner { grid-template-columns: 1fr; }
    .gate-teaser {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-right: none;
      border-bottom: var(--hair-dark);
      padding: 28px 28px;
    }
    .gt-item { padding: 0; }
    .gt-divider { display: none; }
    .gate-cta { padding: 32px 28px; }
    .gu-inner { padding: 30px 28px; }
  }
</style>
