---
interface Props {
  name:        string;
  location:    string;
  tagline:     string;
  heroImage?:  string;
  imageCredit?: string;
  teaser: {
    targetIRR:      string;
    equityMultiple: string;
    holdYears:      number;
  };
  propertyType: string;
  units:        number;
}
const { name, location, tagline, heroImage, imageCredit, teaser, propertyType, units } = Astro.props;
const [namePart1, ...rest] = name.split(' ');
const namePart2 = rest.join(' ');
---
<section class="hero" id="main-content" aria-label="Deal overview">
  {heroImage ? (
    <div class="hero-bg" aria-hidden="true">
      <img src={heroImage} alt="" class="hero-bg-img" />
      <div class="hero-bg-overlay"></div>
    </div>
  ) : (
    <div class="hero-bg hero-bg--gradient" aria-hidden="true"></div>
  )}

  <div class="wrap hero-inner">
    <div class="hero-content">
      <div class="hero-meta label">
        <span class="deal-type">{propertyType}</span>
        <span class="sep" aria-hidden="true">/</span>
        <span>{units} Units</span>
        <span class="sep" aria-hidden="true">/</span>
        <span>{location}</span>
      </div>

      <h1 class="hero-title">
        <span class="line"><span class="title-line1">{namePart1}</span></span>
        <span class="line"><span class="title-line2">{namePart2}</span></span>
      </h1>

      <p class="hero-tagline">{tagline}</p>
    </div>

    <!-- Teaser KPIs — public above the gate -->
    <div class="teaser-strip">
      <div class="teaser-kpi">
        <div class="teaser-label">Target LP IRR</div>
        <div class="teaser-val">{teaser.targetIRR}</div>
      </div>
      <div class="teaser-kpi">
        <div class="teaser-label">Equity Multiple</div>
        <div class="teaser-val">{teaser.equityMultiple}</div>
      </div>
      <div class="teaser-kpi">
        <div class="teaser-label">Target Hold</div>
        <div class="teaser-val">{teaser.holdYears} <span class="unit">yrs</span></div>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span class="scroll-rule"></span>
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--espresso);
    overflow: hidden;
    color: var(--bone);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  /* Firelight — embers glowing in warm dark (no image) */
  .hero-bg--gradient {
    background:
      radial-gradient(100% 80% at 74% 26%, rgba(199,93,58,.34) 0%, transparent 55%),
      radial-gradient(90% 70% at 16% 92%, rgba(90,38,32,.55) 0%, transparent 60%),
      linear-gradient(158deg, var(--espresso-2) 0%, var(--espresso) 62%);
  }
  /* Duotone treatment — warm, desaturated, art-directed */
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    filter: grayscale(.58) contrast(1.05) saturate(.8) brightness(.74);
  }
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(0deg, rgba(27,21,18,.92) 0%, rgba(27,21,18,.5) 45%, rgba(27,21,18,.42) 100%),
      radial-gradient(110% 80% at 78% 22%, rgba(240,163,94,.16) 0%, transparent 52%),
      linear-gradient(140deg, rgba(90,38,32,.32) 0%, transparent 60%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 120px;
    padding-bottom: 88px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .hero-content {
    max-width: 940px;
  }

  .hero-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    color: var(--mist);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .hero-meta .deal-type { color: var(--ember-glow); }
  .hero-meta .sep { color: var(--smoke); }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 300;
    line-height: .94;
    letter-spacing: -.02em;
    color: var(--bone);
  }
  .hero-title .line { display: block; overflow: hidden; padding-bottom: .05em; }
  .title-line1 {
    display: block;
    font-size: clamp(56px, 9vw, 116px);
  }
  .title-line2 {
    display: block;
    font-size: clamp(56px, 9vw, 116px);
    font-style: italic;     /* Fraunces italic — editorial lift on the second line */
    font-weight: 300;
    color: var(--bone);
    margin-top: .02em;
  }

  .hero-tagline {
    margin-top: 30px;
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.7;
    color: var(--mist);
    max-width: 580px;
  }

  /* Teaser strip — editorial figures on a hairline */
  .teaser-strip {
    display: flex;
    align-items: stretch;
    gap: 0;
    border-top: var(--hair-dark);
    padding-top: 28px;
    width: fit-content;
    max-width: 100%;
  }
  .teaser-kpi {
    padding-right: 56px;
    margin-right: 56px;
    border-right: var(--hair-dark);
  }
  .teaser-kpi:last-child { padding-right: 0; margin-right: 0; border-right: none; }
  .teaser-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--mist);
    margin-bottom: 12px;
  }
  .teaser-val {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(34px, 4vw, 46px);
    color: var(--bone);
    line-height: 1;
  }
  .teaser-val .unit { font-size: .5em; color: var(--mist); font-family: var(--font-mono); }

  /* Scroll cue — static, no pulse */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    right: var(--gutter);
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--smoke);
  }
  .scroll-rule {
    width: 40px;
    height: 1px;
    background: var(--smoke);
  }

  @media (max-width: 700px) {
    .teaser-strip { flex-wrap: wrap; gap: 24px; }
    .teaser-kpi { padding-right: 28px; margin-right: 28px; }
    .scroll-hint { display: none; }
  }
</style>
